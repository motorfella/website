---
import BaseLayout from '../layouts/BaseLayout.astro';
import JoinBanner from '../components/JoinBanner.astro';
import EventCard from '../components/EventCard.astro';
import RouteCard from '../components/RouteCard.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';
import { WHATSAPP_GROUP_URL } from '../config';
import gallery from '../data/gallery.json';

const allEvents = await getCollection('events');
const upcoming = allEvents
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => a.data.date.localeCompare(b.data.date))
  .slice(0, 2);

const allRoutes = await getCollection('routes');
const featuredRoutes = allRoutes.slice(0, 2);

const allStories = await getCollection('stories');
const featuredStories = allStories
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const galleryImages = gallery.images.slice(0, 6);
---

<BaseLayout title="Motorfella">

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Parallax background -->
    <div class="absolute inset-0 will-change-transform" id="hero-bg">
      <img
        src="/images/hero-about.jpg"
        alt="Motorfella — red Ducati Supersport"
        class="w-full h-full object-cover scale-110"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#09090B]/75 via-[#09090B]/55 to-[#09090B]"></div>
    </div>

    <!-- Speed line decorations -->
    <div class="absolute top-1/3 left-0 right-0 flex gap-1 pointer-events-none opacity-15">
      <div class="h-px bg-red-600 flex-[3] animate-[line-grow_1.2s_0.8s_cubic-bezier(0.16,1,0.3,1)_both]"></div>
      <div class="h-px bg-red-600 flex-1 animate-[line-grow_1.2s_1.0s_cubic-bezier(0.16,1,0.3,1)_both]"></div>
      <div class="h-px bg-red-600 flex-[2] animate-[line-grow_1.2s_1.2s_cubic-bezier(0.16,1,0.3,1)_both]"></div>
    </div>

    <!-- Red accent bar -->
    <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-red-600 animate-[fade-up_0.8s_0.5s_ease-out_both]"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p class="section-label mb-6 animate-[fade-up_0.5s_0.2s_cubic-bezier(0.16,1,0.3,1)_both]">
        Malaysian Motorcycle Community
      </p>

      <h1 class="font-syncopate font-bold text-white leading-none mb-8 tracking-tight overflow-hidden">
        <span class="block text-5xl sm:text-6xl md:text-8xl animate-[hero-word_0.8s_0.35s_cubic-bezier(0.16,1,0.3,1)_both]">FIRST</span>
        <span class="block text-5xl sm:text-6xl md:text-8xl animate-[hero-word_0.8s_0.5s_cubic-bezier(0.16,1,0.3,1)_both]">GEAR.</span>
        <span class="block text-4xl sm:text-5xl md:text-7xl text-red-500 mt-2 animate-[hero-word_0.8s_0.65s_cubic-bezier(0.16,1,0.3,1)_both]">FULL THROTTLE.</span>
      </h1>

      <div class="flex justify-center mb-8 animate-[fade-up_0.5s_0.85s_ease-out_both]">
        <span class="speed-line w-24"></span>
      </div>

      <p class="text-zinc-300 text-base md:text-lg mb-12 tracking-wide font-light animate-[fade-up_0.5s_0.95s_ease-out_both]">
        Real Rides. Real Brotherhood. Real Stories.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-[fade-up_0.5s_1.05s_ease-out_both]">
        <a href={WHATSAPP_GROUP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Join the Ride
        </a>
        <a href="/routes.html" class="btn-secondary">
          Explore Routes
        </a>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-zinc-400 animate-[fade-up_0.5s_1.4s_ease-out_both]">
      <span class="text-[9px] tracking-[0.35em] uppercase font-syncopate">Scroll</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ═══ WHO WE ARE ═══ -->
  <section class="py-24 px-6 bg-[#09090B] border-t border-zinc-900">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal-left">
          <p class="section-label mb-4">Who We Are</p>
          <span class="speed-line-sm mb-6 block"></span>
          <h2 class="font-syncopate text-3xl md:text-4xl font-bold text-white leading-tight mb-6 tracking-tight">
            BUILT ON COURAGE,<br/>FUELLED BY BROTHERHOOD
          </h2>
        </div>
        <div class="reveal" data-delay="100">
          <p class="text-zinc-400 text-base leading-relaxed mb-6">
            Motorfella is a Malaysian motorcycle community built on courage, discipline, and brotherhood.
            We ride with purpose — prioritising safety, respecting the road, and looking out for one another.
          </p>
          <a href="/about.html" class="group inline-flex items-center gap-3 text-white font-syncopate text-xs tracking-[0.2em] uppercase hover:text-red-400 transition-colors duration-200">
            Our Story
            <span class="speed-line w-8 group-hover:w-14 transition-all duration-300"></span>
          </a>
        </div>
      </div>

      <!-- Stats row -->
      <div class="mt-16 grid grid-cols-3 gap-4 md:gap-8 border-t border-zinc-900 pt-16">
        {[
          { value: '200+', label: 'Active Riders' },
          { value: '5+', label: 'Epic Routes' },
          { value: 'MY', label: 'Based in Malaysia' },
        ].map((stat, i) => (
          <div class="text-center reveal" data-delay={i * 120}>
            <div class="font-syncopate text-3xl md:text-5xl font-bold text-white mb-2">{stat.value}</div>
            <div class="text-xs tracking-[0.2em] uppercase text-zinc-500 font-syncopate">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ UPCOMING EVENTS ═══ -->
  <section class="py-20 px-6 bg-[#0D0D0F] border-t border-zinc-900">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <p class="section-label mb-3">On the Calendar</p>
          <h2 class="font-syncopate text-2xl md:text-3xl font-bold text-white tracking-tight">
            UPCOMING RIDES
          </h2>
        </div>
        <a href="/events.html" class="hidden md:flex items-center gap-3 text-zinc-500 hover:text-white text-xs tracking-[0.2em] uppercase font-syncopate transition-colors group">
          All Events
          <span class="speed-line w-6 group-hover:w-10 transition-all duration-300 opacity-60 group-hover:opacity-100"></span>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {upcoming.map((event, i) => (
          <div class="reveal card-lift" data-delay={i * 120}>
            <EventCard
              title={event.data.title}
              date={event.data.date}
              end_date={event.data.end_date}
              location={event.data.location}
              meeting_point={event.data.meeting_point}
              departure_time={event.data.departure_time}
              distance_km={event.data.distance_km}
              status={event.data.status}
              hero_image={event.data.hero_image}
              slug={event.id}
              whatsapp_link={event.data.whatsapp_link}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden text-center">
        <a href="/events.html" class="text-zinc-400 hover:text-white text-sm font-medium transition-colors">
          All Events →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED ROUTES ═══ -->
  <section class="py-20 px-6 bg-[#09090B] border-t border-zinc-900">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <p class="section-label mb-3">Hit the Road</p>
          <h2 class="font-syncopate text-2xl md:text-3xl font-bold text-white tracking-tight">
            FEATURED ROUTES
          </h2>
        </div>
        <a href="/routes.html" class="hidden md:flex items-center gap-3 text-zinc-500 hover:text-white text-xs tracking-[0.2em] uppercase font-syncopate transition-colors group">
          All Routes
          <span class="speed-line w-6 group-hover:w-10 transition-all duration-300 opacity-60 group-hover:opacity-100"></span>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {featuredRoutes.map((route, i) => (
          <div class="reveal card-lift" data-delay={i * 120}>
            <RouteCard
              title={route.data.title}
              distance_km={route.data.distance_km}
              duration_days={route.data.duration_days}
              difficulty={route.data.difficulty}
              hero_image={route.data.hero_image}
              slug={route.id}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden text-center">
        <a href="/routes.html" class="text-zinc-400 hover:text-white text-sm font-medium transition-colors">
          All Routes →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ STORIES & VIDEOS ═══ -->
  <section class="py-20 px-6 bg-[#0D0D0F] border-t border-zinc-900">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <p class="section-label mb-3">From the Road</p>
          <h2 class="font-syncopate text-2xl md:text-3xl font-bold text-white tracking-tight">
            LATEST STORIES & VLOGS
          </h2>
        </div>
        <a href="/stories.html" class="hidden md:flex items-center gap-3 text-zinc-500 hover:text-white text-xs tracking-[0.2em] uppercase font-syncopate transition-colors group">
          All Stories
          <span class="speed-line w-6 group-hover:w-10 transition-all duration-300 opacity-60 group-hover:opacity-100"></span>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {featuredStories.map((story, i) => (
          <div class="reveal card-lift" data-delay={i * 100}>
            <StoryCard
              title={story.data.title}
              author={story.data.author}
              date={story.data.date}
              type={story.data.type}
              excerpt={story.data.excerpt}
              hero_image={story.data.hero_image}
              slug={story.id}
              youtube_url={story.data.youtube_url}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden text-center">
        <a href="/stories.html" class="text-zinc-400 hover:text-white text-sm font-medium transition-colors">
          All Stories →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ GALLERY PREVIEW ═══ -->
  <section class="py-20 px-6 bg-[#09090B] border-t border-zinc-900">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <p class="section-label mb-3">In the Lens</p>
          <h2 class="font-syncopate text-2xl md:text-3xl font-bold text-white tracking-tight">
            GALLERY
          </h2>
        </div>
        <a href="/gallery.html" class="hidden md:flex items-center gap-3 text-zinc-500 hover:text-white text-xs tracking-[0.2em] uppercase font-syncopate transition-colors group">
          Full Gallery
          <span class="speed-line w-6 group-hover:w-10 transition-all duration-300 opacity-60 group-hover:opacity-100"></span>
        </a>
      </div>

      <!-- Mosaic grid: first image larger -->
      <div class="grid grid-cols-3 md:grid-cols-4 gap-2 md:gap-3">
        {galleryImages.slice(0, 1).map((image, i) => (
          <div class="col-span-2 row-span-2 aspect-square md:aspect-auto md:h-64 bg-zinc-900 overflow-hidden group reveal-scale" data-delay="0">
            <img
              src={image.src}
              alt={image.alt || `Gallery image ${i + 1}`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
        {galleryImages.slice(1).map((image, i) => (
          <div class="aspect-square bg-zinc-900 overflow-hidden group reveal-scale" data-delay={(i + 1) * 80}>
            <img
              src={image.src}
              alt={image.alt || `Gallery image ${i + 2}`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden text-center">
        <a href="/gallery.html" class="text-zinc-400 hover:text-white text-sm font-medium transition-colors">
          Full Gallery →
        </a>
      </div>
    </div>
  </section>

  <JoinBanner />

</BaseLayout>

<script>
  // Hero parallax
  const heroBg = document.getElementById('hero-bg');
  if (heroBg) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      heroBg.style.transform = `translateY(${y * 0.25}px)`;
    }, { passive: true });
  }
</script>
