---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JoinBanner from '../../components/JoinBanner.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const routes = await getCollection('routes');
  return routes.map(route => ({ params: { slug: route.id } }));
}

const { slug } = Astro.params;
const route = await getEntry('routes', slug!);

if (!route) return Astro.redirect('/routes');

const { Content } = await render(route);

const difficultyLabel: Record<string, string> = {
  easy: '★☆☆☆☆ Easy',
  moderate: '★★★☆☆ Moderate',
  challenging: '★★★★☆ Challenging',
  epic: '★★★★★ Epic',
};
---

<BaseLayout title={route.data.title} description={`${route.data.distance_km} KM · ${route.data.duration_days} day${route.data.duration_days > 1 ? 's' : ''} · ${route.data.region}`}>

  <!-- Back -->
  <div class="bg-zinc-950 px-4 pt-8">
    <div class="max-w-4xl mx-auto">
      <a href="/routes" class="text-zinc-500 hover:text-white text-sm transition-colors">← Back to Routes</a>
    </div>
  </div>

  <!-- Hero Image -->
  <div class="bg-zinc-950 px-4 pt-4">
    <div class="max-w-4xl mx-auto">
      <div class="aspect-video rounded overflow-hidden bg-zinc-800">
        <img src={route.data.hero_image} alt={route.data.title} class="w-full h-full object-cover" />
      </div>
    </div>
  </div>

  <!-- Route Info -->
  <section class="py-10 px-4 bg-zinc-950">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-black text-white mb-6">{route.data.title}</h1>

      <!-- Stat Bar -->
      <div class="flex flex-wrap gap-6 mb-10 pb-8 border-b border-zinc-800">
        <div class="text-center">
          <p class="text-2xl font-bold text-white">{route.data.distance_km} KM</p>
          <p class="text-zinc-500 text-sm">Distance</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-white">{route.data.duration_days} {route.data.duration_days === 1 ? 'Day' : 'Days'}</p>
          <p class="text-zinc-500 text-sm">Duration</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold text-white">{route.data.region}</p>
          <p class="text-zinc-500 text-sm">Region</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold text-white">{difficultyLabel[route.data.difficulty]}</p>
          <p class="text-zinc-500 text-sm">Difficulty</p>
        </div>
      </div>

      <!-- Overview Content -->
      <div class="prose prose-invert prose-zinc max-w-none mb-10">
        <Content />
      </div>

      <!-- Key Stops -->
      {route.data.key_stops.length > 0 && (
        <div class="mb-10">
          <h2 class="text-xl font-bold text-white mb-4">Key Stops</h2>
          <ul class="space-y-2">
            {route.data.key_stops.map(stop => (
              <li class="flex gap-2 text-zinc-300">
                <span class="text-zinc-600">•</span>
                {stop}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Map Placeholder -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-white mb-4">Map</h2>
        <div class="aspect-video bg-zinc-800 rounded flex items-center justify-center">
          <p class="text-zinc-600 text-sm">Map embed or image — add per route</p>
        </div>
      </div>

      <!-- Rider Tips -->
      {route.data.tips.length > 0 && (
        <div class="mb-10">
          <h2 class="text-xl font-bold text-white mb-4">Tips From Our Riders</h2>
          <div class="space-y-3">
            {route.data.tips.map(tip => (
              <div class="bg-zinc-900 border-l-4 border-zinc-600 px-4 py-3">
                <p class="text-zinc-300 italic">"{tip}"</p>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <JoinBanner />

</BaseLayout>
