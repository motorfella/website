---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WHATSAPP_GROUP_URL } from '../config';

const benefits = [
  { icon: 'MAP', title: 'Organised Rides', desc: 'Monthly group trips, curated routes, proper briefings, and sweep riders. You focus on the ride.' },
  { icon: 'CREW', title: 'Real Community', desc: 'Riders who actually look out for each other on the road. Not just a chat group.' },
  { icon: 'PIN', title: 'Route Intel', desc: 'Tested routes, local tips, fuel stop intel, and road condition updates from our riders.' },
  { icon: 'FILM', title: 'Stories & Videos', desc: 'Ride recaps, expedition films, and stories from members. Live through every journey.' },
];

const testimonials = [
  { quote: 'Best decision I made as a rider. These guys are the real deal.', name: 'REPLACE WITH REAL MEMBER NAME', location: 'Kuala Lumpur' },
  { quote: "First group I've ridden with where safety is actually taken seriously. No ego, just brotherhood.", name: 'REPLACE WITH REAL MEMBER NAME', location: 'Selangor' },
];

const steps = ['Tap the button below.', 'Introduce yourself in the group.', 'Join the next ride.'];
---

<BaseLayout title="Join Us" description="Join the Motorfella WhatsApp community - ride with Malaysian motorcyclists.">

  <!-- HERO -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-join.jpg" alt="Group ride" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#09090B]/60 via-[#09090B]/70 to-[#09090B]"></div>
    </div>
    <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-red-600"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
      <p class="section-label mb-4">Community</p>
      <h1 class="font-syncopate font-bold text-4xl md:text-6xl text-white leading-none tracking-tight mb-6">
        RIDE<br/>WITH US.
      </h1>
      <div class="flex justify-center mb-6"><span class="speed-line w-16"></span></div>
      <p class="text-zinc-400 text-base leading-relaxed">This isn't just a group.<br/>It's brotherhood on wheels.</p>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="py-20 px-6 bg-[#09090B]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="section-label mb-3">What You Get</p>
        <h2 class="font-syncopate text-2xl md:text-3xl font-bold text-white tracking-tight">THE PERKS</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {benefits.map((b) => (
          <div class="card-dark border-l-2 border-l-red-600 p-6">
            <span class="inline-block font-syncopate text-[9px] font-bold tracking-[0.3em] text-red-500 border border-red-900 px-2 py-1 mb-4">{b.icon}</span>
            <h3 class="font-syncopate text-white font-bold text-sm tracking-wide uppercase mb-3">{b.title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW TO JOIN -->
  <section class="py-20 px-6 bg-[#0D0D0F] border-t border-zinc-900">
    <div class="max-w-lg mx-auto text-center">
      <p class="section-label mb-3">It's Simple</p>
      <h2 class="font-syncopate text-2xl font-bold text-white mb-12 tracking-tight">HOW TO JOIN</h2>
      <div class="space-y-6 mb-10 text-left">
        {steps.map((step, i) => (
          <div class="flex items-center gap-5">
            <div class="w-10 h-10 bg-red-600 font-syncopate font-bold text-white flex items-center justify-center flex-shrink-0 text-sm">
              {i + 1}
            </div>
            <p class="text-zinc-300">{step}</p>
          </div>
        ))}
      </div>
      <p class="text-zinc-400 text-sm font-syncopate tracking-widest uppercase">That's it.</p>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-20 px-6 bg-[#09090B] border-t border-zinc-900">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="section-label mb-3">From the Fellas</p>
        <h2 class="font-syncopate text-2xl font-bold text-white tracking-tight">WHAT MEMBERS SAY</h2>
      </div>
      <div class="space-y-5">
        {testimonials.map((t) => (
          <div class="card-dark border-l-2 border-l-red-600 p-6 md:p-8">
            <p class="text-zinc-300 text-lg italic leading-relaxed mb-5">"{t.quote}"</p>
            <p class="text-[11px] font-syncopate tracking-[0.2em] uppercase text-zinc-400">
              {t.name} <span class="text-zinc-500">·</span> {t.location}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-24 px-6 bg-[#0D0D0F] border-t border-zinc-900 text-center">
    <p class="section-label mb-4">Ready?</p>
    <h2 class="font-syncopate text-3xl md:text-4xl font-bold text-white mb-8 tracking-tight">LET'S RIDE.</h2>
    <a href={WHATSAPP_GROUP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
      Join WhatsApp Group
    </a>
  </section>

</BaseLayout>
