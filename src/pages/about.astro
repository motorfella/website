---
import BaseLayout from '../layouts/BaseLayout.astro';
import JoinBanner from '../components/JoinBanner.astro';

const values = [
  { icon: '🛡️', title: 'Safety First', desc: 'Full gear. Proper briefings. No exceptions on the road.' },
  { icon: '🧭', title: 'Discipline On Road', desc: 'Ride formation, speed discipline, and sweep riders on every trip.' },
  { icon: '🤝', title: 'Brotherhood', desc: 'We look out for each other. Nobody gets left behind.' },
  { icon: '🏔️', title: 'Growth & Adventure', desc: 'Push your limits wisely. Every ride makes you a better rider.' },
];

const founders = [
  {
    name: 'REPLACE WITH NAME',
    role: 'Founder',
    bike: 'REPLACE WITH BIKE',
    quote: 'REPLACE WITH QUOTE',
    image: '/images/team/founder-1.jpg',
  },
  {
    name: 'REPLACE WITH NAME',
    role: 'Co-Founder',
    bike: 'REPLACE WITH BIKE',
    quote: 'REPLACE WITH QUOTE',
    image: '/images/team/founder-2.jpg',
  },
];
---

<BaseLayout title="About" description="The story behind Motorfella — a Malaysian motorcycle community built on brotherhood, safety, and adventure.">

  <!-- PAGE HERO -->
  <section class="relative py-24 px-4 text-center bg-zinc-950">
    <div class="absolute inset-0">
      <img src="/images/hero-about.jpg" alt="Motorfella riders" class="w-full h-full object-cover opacity-25" />
    </div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4">We Are Motorfella</h1>
      <p class="text-zinc-300 text-xl">Riders. Brothers. Storytellers.</p>
    </div>
  </section>

  <!-- OUR STORY -->
  <section class="py-16 px-4 bg-zinc-950">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-6">Our Story</h2>
      <div class="mb-8">
        <img src="/images/about-group.jpg" alt="Motorfella group" class="w-full rounded object-cover aspect-video bg-zinc-800" />
      </div>
      <div class="prose prose-invert prose-zinc max-w-none text-zinc-300 text-lg leading-relaxed space-y-4">
        <p>REPLACE WITH REAL ORIGIN STORY — who started it, when, why.</p>
        <p>REPLACE WITH WHAT THE COMMUNITY HAS BECOME — member count, rides done, distances covered.</p>
        <p>REPLACE WITH THE FUTURE — where Motorfella is going.</p>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-16 px-4 bg-zinc-900">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-10 text-center">What We Stand For</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {values.map(v => (
          <div class="bg-zinc-800 rounded p-5 text-center">
            <div class="text-3xl mb-3">{v.icon}</div>
            <h3 class="text-white font-bold mb-2">{v.title}</h3>
            <p class="text-zinc-400 text-sm">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOUNDERS -->
  <section class="py-16 px-4 bg-zinc-950">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-10">The Founding Riders</h2>
      <div class="space-y-8">
        {founders.map(f => (
          <div class="flex gap-5 items-start">
            <img
              src={f.image}
              alt={f.name}
              class="w-20 h-20 rounded-full object-cover bg-zinc-800 flex-shrink-0"
            />
            <div>
              <p class="text-white font-bold text-lg">{f.name}</p>
              <p class="text-zinc-500 text-sm mb-2">{f.role} · {f.bike}</p>
              <p class="text-zinc-300 italic">"{f.quote}"</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <JoinBanner heading="Ready to ride with us?" />

</BaseLayout>
