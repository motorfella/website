---
import BaseLayout from '../layouts/BaseLayout.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';
import { WHATSAPP_GROUP_URL } from '../config';

const allStories = await getCollection('stories');
const textStories = allStories
  .filter(s => s.data.type === 'story')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
const videos = allStories
  .filter(s => s.data.type === 'video')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const featured = textStories.find(s => s.data.featured) ?? textStories[0];
const restStories = textStories.filter(s => s.id !== featured?.id);
---

<BaseLayout title="Stories & Videos" description="Ride stories, expedition films, and route recaps from Motorfella.">

  <section class="py-20 px-6 bg-[#09090B]">
    <div class="max-w-7xl mx-auto">

      <!-- Header -->
      <div class="mb-14 border-l-2 border-l-red-600 pl-6">
        <p class="section-label mb-3">From the Road</p>
        <h1 class="font-syncopate font-bold text-4xl md:text-5xl text-white leading-none tracking-tight">
          STORIES<br/>& VLOGS
        </h1>
        <p class="text-zinc-500 mt-4 text-sm tracking-wide">By our riders. For our riders.</p>
      </div>

      <!-- Tabs -->
      <div class="flex gap-0 mb-12 border-b border-zinc-900">
        <button
          id="tab-stories"
          class="tab-btn px-6 py-3 text-[11px] font-bold tracking-[0.2em] uppercase font-syncopate text-white border-b-2 border-red-600 transition-colors cursor-pointer"
          data-tab="stories"
        >
          Stories
        </button>
        <button
          id="tab-videos"
          class="tab-btn px-6 py-3 text-[11px] font-bold tracking-[0.2em] uppercase font-syncopate text-zinc-400 border-b-2 border-transparent hover:text-zinc-300 transition-colors cursor-pointer"
          data-tab="videos"
        >
          Vlogs
        </button>
      </div>

      <!-- Stories Panel -->
      <div id="panel-stories">
        {featured && (
          <div class="mb-8">
            <StoryCard
              title={featured.data.title}
              author={featured.data.author}
              date={featured.data.date}
              type={featured.data.type}
              excerpt={featured.data.excerpt}
              hero_image={featured.data.hero_image}
              slug={featured.id}
              featured={true}
            />
          </div>
        )}
        {restStories.length > 0 && (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {restStories.map(story => (
              <StoryCard
                title={story.data.title}
                author={story.data.author}
                date={story.data.date}
                type={story.data.type}
                excerpt={story.data.excerpt}
                hero_image={story.data.hero_image}
                slug={story.id}
              />
            ))}
          </div>
        )}
      </div>

      <!-- Videos Panel -->
      <div id="panel-videos" class="hidden">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.map(video => (
            <StoryCard
              title={video.data.title}
              author={video.data.author}
              date={video.data.date}
              type={video.data.type}
              excerpt={video.data.excerpt}
              hero_image={video.data.hero_image}
              slug={video.id}
              youtube_url={video.data.youtube_url}
            />
          ))}
        </div>
      </div>

      <!-- Share CTA -->
      <div class="mt-20 pt-12 border-t border-zinc-900 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="section-label mb-2">Got a story?</p>
          <p class="text-zinc-500 text-sm">Share your ride with the community.</p>
        </div>
        <a
          href={WHATSAPP_GROUP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary whitespace-nowrap"
        >
          Share via WhatsApp
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels: Record<string, HTMLElement | null> = {
    stories: document.getElementById('panel-stories'),
    videos: document.getElementById('panel-videos'),
  };

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach(t => {
        const active = t.dataset.tab === target;
        t.classList.toggle('text-white', active);
        t.classList.toggle('border-red-600', active);
        t.classList.toggle('text-zinc-400', !active);
        t.classList.toggle('border-transparent', !active);
      });
      Object.entries(panels).forEach(([key, panel]) => {
        panel?.classList.toggle('hidden', key !== target);
      });
    });
  });
</script>
