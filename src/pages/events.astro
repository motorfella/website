---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import JoinBanner from '../components/JoinBanner.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const upcoming = allEvents
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => a.data.date.localeCompare(b.data.date));
const past = allEvents
  .filter(e => e.data.status === 'past')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title="Events" description="Upcoming rides and events from Motorfella — join us on the road.">

  <section class="py-16 px-4 bg-zinc-950">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-black text-white mb-3">Rides & Events</h1>
      <p class="text-zinc-400 text-lg mb-12">Where the road takes us next.</p>

      <!-- Upcoming -->
      <h2 class="text-xl font-bold text-zinc-300 uppercase tracking-widest mb-6">Upcoming</h2>
      {upcoming.length === 0 && (
        <p class="text-zinc-500 mb-12">No upcoming events right now. Check back soon — or join the WhatsApp group to hear first.</p>
      )}
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        {upcoming.map(event => (
          <EventCard
            title={event.data.title}
            date={event.data.date}
            end_date={event.data.end_date}
            location={event.data.location}
            meeting_point={event.data.meeting_point}
            departure_time={event.data.departure_time}
            distance_km={event.data.distance_km}
            status={event.data.status}
            hero_image={event.data.hero_image}
            slug={event.id}
            whatsapp_link={event.data.whatsapp_link}
          />
        ))}
      </div>

      <!-- Past Rides -->
      {past.length > 0 && (
        <>
          <h2 class="text-xl font-bold text-zinc-500 uppercase tracking-widest mb-6">Past Rides</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {past.map(event => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                end_date={event.data.end_date}
                location={event.data.location}
                meeting_point={event.data.meeting_point}
                departure_time={event.data.departure_time}
                distance_km={event.data.distance_km}
                status={event.data.status}
                hero_image={event.data.hero_image}
                slug={event.id}
                recap_slug={event.data.recap_slug}
              />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <JoinBanner heading="Never miss a ride." />

</BaseLayout>
