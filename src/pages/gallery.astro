---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WHATSAPP_GROUP_URL } from '../config';

// Replace these placeholders with real gallery photography as assets are supplied.
const images = [
  { src: '/images/gallery/01.jpg', alt: 'Ride photo 1', category: 'rides' },
  { src: '/images/gallery/02.jpg', alt: 'Event photo 1', category: 'events' },
  { src: '/images/gallery/03.jpg', alt: 'Route photo 1', category: 'routes' },
  { src: '/images/gallery/04.jpg', alt: 'Riders 1', category: 'people' },
  { src: '/images/gallery/05.jpg', alt: 'Ride photo 2', category: 'rides' },
  { src: '/images/gallery/06.jpg', alt: 'Event photo 2', category: 'events' },
];

const categories = ['all', 'rides', 'events', 'routes', 'people'];
---

<BaseLayout title="Gallery" description="Motorfella photo gallery - real rides, real moments.">
  <section class="py-16 px-4 bg-zinc-950">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-black text-white mb-3">Gallery</h1>
      <p class="text-zinc-400 text-lg mb-10">Real rides. Real moments.</p>

      <div class="flex flex-wrap gap-3 mb-10" id="category-filters">
        {categories.map((cat) => (
          <button
            class:list={[
              'filter-btn px-4 py-2 rounded text-sm font-medium transition-colors',
              cat === 'all' ? 'bg-white text-zinc-950' : 'bg-zinc-800 text-zinc-400 hover:text-white',
            ]}
            data-category={cat}
          >
            {cat.charAt(0).toUpperCase() + cat.slice(1)}
          </button>
        ))}
      </div>

      <div class="columns-2 md:columns-3 gap-4 space-y-4" id="gallery-grid">
        {images.map((img, i) => (
          <div class="gallery-item break-inside-avoid" data-category={img.category}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full rounded object-cover hover:opacity-90 transition-opacity cursor-pointer"
              loading={i < 6 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>

      <div class="mt-16 pt-12 border-t border-zinc-800 text-center">
        <p class="text-zinc-400 mb-4">Share your ride photos with the community.</p>
        <a
          href={WHATSAPP_GROUP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border border-zinc-600 text-zinc-300 font-medium px-6 py-3 rounded hover:border-white hover:text-white transition-colors"
        >
          Send to WhatsApp Group
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.category!;

      filterBtns.forEach((button) => {
        const isActive = button.dataset.category === target;
        button.classList.toggle('bg-white', isActive);
        button.classList.toggle('text-zinc-950', isActive);
        button.classList.toggle('bg-zinc-800', !isActive);
        button.classList.toggle('text-zinc-400', !isActive);
      });

      items.forEach((item) => {
        const match = target === 'all' || item.dataset.category === target;
        item.style.display = match ? '' : 'none';
      });
    });
  });
</script>
