---
import { SITE_LOGO, SITE_NAME, WHATSAPP_GROUP_URL } from '../config';

const navLinks = [
  { href: '/routes.html', match: '/routes', label: 'Routes' },
  { href: '/events.html', match: '/events', label: 'Events' },
  { href: '/stories.html', match: '/stories', label: 'Stories' },
  { href: '/gallery.html', match: '/gallery', label: 'Gallery' },
  { href: '/about.html', match: '/about', label: 'About' },
  { href: '/contact.html', match: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-[#09090B]/95 backdrop-blur-sm border-b border-zinc-900 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">

    <!-- Mobile: Hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden p-2 text-zinc-400 hover:text-white transition-colors cursor-pointer"
      aria-label="Open menu"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      {SITE_LOGO ? (
        <img src={SITE_LOGO} alt={`${SITE_NAME} logo`} class="h-8 w-auto" />
      ) : (
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-6 bg-red-600 inline-block transition-all duration-200 group-hover:h-5"></span>
          <span class="font-syncopate font-bold text-lg tracking-[0.2em] text-white uppercase group-hover:text-red-400 transition-colors duration-200">
            {SITE_NAME}
          </span>
        </span>
      )}
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden md:flex items-center gap-7">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.match);
        return (
          <li>
            <a
              href={link.href}
              class={`text-sm font-medium tracking-wide pb-0.5 transition-all duration-200 relative ${
                isActive
                  ? 'text-white border-b-2 border-red-600'
                  : 'text-zinc-400 hover:text-white border-b-2 border-transparent hover:border-zinc-600'
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- JOIN Button -->
    <a
      href={WHATSAPP_GROUP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-red-600 hover:bg-red-500 text-white text-xs font-bold px-4 py-2 tracking-[0.15em] uppercase font-syncopate transition-all duration-200 cursor-pointer hover:shadow-md hover:shadow-red-950/60 hover:-translate-y-px"
    >
      JOIN
    </a>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#09090B] border-t border-zinc-900">
    <ul class="flex flex-col px-5 py-5 gap-1">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.match);
        return (
          <li>
            <a
              href={link.href}
              class={`block text-base font-medium py-2.5 transition-colors border-b border-zinc-900 last:border-0 ${
                isActive ? 'text-red-400' : 'text-zinc-300 hover:text-white'
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
    <div class="px-5 pb-5 pt-2">
      <a
        href={WHATSAPP_GROUP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full bg-red-600 hover:bg-red-500 text-white text-sm font-bold py-3 text-center tracking-[0.15em] uppercase font-syncopate transition-colors"
      >
        JOIN THE RIDE
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const nav = document.getElementById('main-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle?.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav?.classList.add('shadow-lg', 'shadow-black/60', '!border-b-zinc-800');
    } else {
      nav?.classList.remove('shadow-lg', 'shadow-black/60', '!border-b-zinc-800');
    }
  }, { passive: true });
</script>
