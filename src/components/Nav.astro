---
import { SITE_LOGO, SITE_NAME, WHATSAPP_GROUP_URL } from '../config';

const navLinks = [
  { href: '/routes', label: 'Routes' },
  { href: '/events', label: 'Events' },
  { href: '/stories', label: 'Stories' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/95 backdrop-blur border-b border-zinc-800">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">

    <!-- Mobile: Hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden p-2 text-zinc-300 hover:text-white"
      aria-label="Open menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 text-xl font-bold tracking-widest text-white uppercase">
      {SITE_LOGO ? (
        <img src={SITE_LOGO} alt={`${SITE_NAME} logo`} class="h-9 w-auto" />
      ) : null}
      <span>{SITE_NAME}</span>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium tracking-wide transition-colors ${
              currentPath.startsWith(link.href)
                ? 'text-white'
                : 'text-zinc-400 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- JOIN Button (always visible) -->
    <a
      href={WHATSAPP_GROUP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-white text-zinc-950 text-sm font-bold px-4 py-2 rounded hover:bg-zinc-100 transition-colors"
    >
      JOIN
    </a>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-zinc-900 border-t border-zinc-800">
    <ul class="flex flex-col px-4 py-4 gap-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block text-zinc-300 hover:text-white font-medium py-1"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle?.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
