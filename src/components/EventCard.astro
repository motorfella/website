---
import { WHATSAPP_GROUP_URL } from '../config';

interface Props {
  title: string;
  date: string;
  end_date?: string;
  location: string;
  meeting_point: string;
  departure_time: string;
  distance_km: number;
  status: 'upcoming' | 'past';
  hero_image: string;
  slug: string;
  whatsapp_link?: string;
  recap_slug?: string;
}

const {
  title, date, end_date, location, meeting_point, departure_time,
  distance_km, status, hero_image, slug, whatsapp_link, recap_slug,
} = Astro.props;

const rsvpUrl = whatsapp_link ?? WHATSAPP_GROUP_URL;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-MY', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

const dateDisplay = end_date
  ? `${formatDate(date)} – ${formatDate(end_date)}`
  : formatDate(date);
---

<div class="bg-zinc-900 rounded overflow-hidden">
  <div class="aspect-video bg-zinc-800 overflow-hidden">
    <img src={hero_image} alt={title} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-5">
    <p class="text-zinc-400 text-sm font-medium mb-1">{dateDisplay}</p>
    <h3 class="text-white font-bold text-xl mb-4">{title}</h3>
    <div class="space-y-1 text-sm text-zinc-400 mb-5">
      <p>📍 {location}</p>
      <p>🕐 Depart {departure_time} from {meeting_point}</p>
      <p>🏍️ {distance_km} KM</p>
    </div>
    {status === 'upcoming' ? (
      <a
        href={rsvpUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-zinc-950 font-bold px-5 py-2.5 rounded text-sm hover:bg-zinc-100 transition-colors"
      >
        RSVP via WhatsApp
      </a>
    ) : recap_slug ? (
      <a
        href={`/stories/${recap_slug}`}
        class="inline-block border border-zinc-700 text-zinc-300 font-medium px-5 py-2.5 rounded text-sm hover:border-zinc-500 hover:text-white transition-colors"
      >
        View Recap
      </a>
    ) : null}
  </div>
</div>
