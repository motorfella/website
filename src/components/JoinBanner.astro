---
import { WHATSAPP_GROUP_URL } from '../config';

interface Props {
  heading?: string;
}

const { heading = 'Ride With Us.' } = Astro.props;
---

<section class="bg-zinc-900 border-t border-zinc-800 py-16 px-4 text-center">
  <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">{heading}</h2>
  <p class="text-zinc-400 mb-8">Join 200+ fellas on WhatsApp.</p>
  <a
    href={WHATSAPP_GROUP_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block bg-white text-zinc-950 font-bold px-8 py-4 rounded text-lg hover:bg-zinc-100 transition-colors"
  >
    Join WhatsApp Group
  </a>
</section>
