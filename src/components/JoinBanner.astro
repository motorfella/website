---
import { WHATSAPP_GROUP_URL } from '../config';

interface Props {
  heading?: string;
}

const { heading = 'RIDE WITH US.' } = Astro.props;
---

<section class="relative overflow-hidden bg-[#0D0D0F] border-t border-zinc-900 py-24 px-6 text-center">
  <!-- Decorations -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-red-600 to-transparent opacity-50"></div>
    <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-red-600 to-transparent opacity-50"></div>
    <div class="absolute top-1/2 -translate-y-1/2 left-0 right-0 flex gap-2 opacity-[0.04]">
      <div class="flex-1 h-px bg-red-600"></div>
      <div class="flex-[2] h-px bg-red-600"></div>
      <div class="flex-1 h-px bg-red-600"></div>
    </div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto reveal">
    <p class="section-label mb-4">Join the Community</p>
    <h2 class="font-syncopate text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight leading-none">
      {heading}
    </h2>
    <div class="flex justify-center mb-8">
      <span class="speed-line w-16"></span>
    </div>
    <p class="text-zinc-400 mb-10 text-base leading-relaxed">
      Join 200+ fellas on WhatsApp. No gatekeeping — just brotherhood.
    </p>
    <a
      href={WHATSAPP_GROUP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary"
    >
      Join WhatsApp Group
    </a>
  </div>
</section>
