---
import { SITE_LOCATION, SITE_LOGO, SITE_NAME, SOCIAL_LINKS } from '../config';

const footerLinks = [
  { href: '/routes', label: 'Routes' },
  { href: '/events', label: 'Events' },
  { href: '/stories', label: 'Stories' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const socialLinks = SOCIAL_LINKS;
---

<footer class="bg-zinc-950 border-t border-zinc-800 py-12 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-1">
          {SITE_LOGO ? <img src={SITE_LOGO} alt={`${SITE_NAME} logo`} class="h-9 w-auto" /> : null}
          <p class="text-xl font-bold tracking-widest text-white uppercase">{SITE_NAME}</p>
        </div>
        <p class="text-zinc-500 text-sm">{SITE_LOCATION}</p>
      </div>

      <!-- Nav Links -->
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {footerLinks.map(link => (
          <a href={link.href} class="text-zinc-400 hover:text-white text-sm transition-colors">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Social -->
      <div class="flex gap-4">
        {socialLinks.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            class="text-zinc-500 hover:text-white text-sm font-medium transition-colors"
          >
            [{s.abbr}]
          </a>
        ))}
      </div>

    </div>

    <div class="mt-8 pt-8 border-t border-zinc-800">
      <p class="text-zinc-600 text-sm">© {new Date().getFullYear()} {SITE_NAME}</p>
    </div>
  </div>
</footer>
